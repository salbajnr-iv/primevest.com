@import "tailwindcss";
@import "../styles/landing-animations.css";
@import "../styles/utilities.css";
@import "../styles/responsive.css";
@import "../styles/micro-interactions.css";
@import "../styles/dashboard-professional.css";
@import "../styles/dashboard-enhancements.css";
@import "../styles/tradewill-dashboard.css";
@import "../styles/tradewill-fix.css";
@import "../styles/markets.css";

/* Smooth scrolling and parallax effects */
html {
  scroll-behavior: smooth;
}

.parallax-scroll {
  transform: translateZ(0);
  will-change: transform;
}

/* Professional typography enhancements */
.text-display {
  font-size: clamp(2.5rem, 5vw, 4rem);
  line-height: 1.1;
  letter-spacing: -0.02em;
  font-weight: 800;
  color: var(--color-brand-text-primary);
}

.text-heading {
  font-size: clamp(1.875rem, 3vw, 3rem);
  line-height: 1.2;
  letter-spacing: -0.01em;
  font-weight: 700;
  color: var(--color-brand-text-primary);
}

.text-subheading {
  font-size: clamp(1.5rem, 2.5vw, 2rem);
  line-height: 1.3;
  letter-spacing: -0.005em;
  font-weight: 600;
  color: var(--color-neutrals-text-primary);
}

.text-body {
  font-size: clamp(1rem, 2vw, 1.125rem);
  line-height: 1.6;
  font-weight: 400;
  color: var(--color-neutrals-text-primary);
}

.text-body-sm {
  font-size: 0.875rem;
  line-height: 1.5;
  font-weight: 400;
  color: var(--color-neutrals-text-secondary);
}

/* Enhanced card styles */
.card-elevated {
  transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
  border: 1px solid rgba(0, 0, 0, 0.03);
  background: linear-gradient(135deg, #ffffff 0%, #fafafa 100%);
}

.card-elevated:hover {
  transform: translateY(-4px);
  box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
  border-color: rgba(16, 185, 129, 0.2);
}

/* Premium card styles */
.card-premium {
  transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05), 0 4px 6px -2px rgba(0, 0, 0, 0.02);
  border: 1px solid rgba(0, 0, 0, 0.05);
  background: linear-gradient(135deg, #ffffff 0%, #f8fdfa 100%);
  position: relative;
  overflow: hidden;
}

.card-premium::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2px;
  background: linear-gradient(90deg, transparent, #10b981, transparent);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.card-premium:hover::before {
  opacity: 1;
}

.card-premium:hover {
  transform: translateY(-4px);
  box-shadow: 0 25px 30px -5px rgba(0, 0, 0, 0.1), 0 15px 15px -5px rgba(0, 0, 0, 0.05);
  border-color: rgba(16, 185, 129, 0.3);
}

/* Professional button styles */
.btn-refined {
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
  border-radius: 0.75rem;
  border: 1px solid transparent;
}

.btn-refined::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  transition: left 0.5s;
  z-index: 1;
}

.btn-refined:hover::before {
  left: 100%;
}

